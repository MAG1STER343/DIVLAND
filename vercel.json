{
  "version": 2,
  "functions": {
    "server/src/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/(main|profile|diversi|discord)",
      "destination": "/index.html"
    },
    {
      "source": "/u/(.*)",
      "destination": "/index.html"
    }
  ]
}
