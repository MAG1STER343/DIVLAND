{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/(main|profile|diversi|discord)",
      "destination": "/index.html"
    },
    {
      "source": "/u/(.*)",
      "destination": "/index.html"
    }
  ]
}
