{
  "version": 2,
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/api/index.js"
    },
    {
      "source": "/(api|auth)/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(main|profile|dieversi|die-versi|discord|participants)(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/u/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|auth|favicon.ico|assets|avatars|sounds|videos|_next|static).*)$",
      "destination": "/index.html"
    }
  ]
}
